# EditorConfig - https://editorconfig.org
# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files - preserve trailing whitespace for line breaks
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# SQL files
[*.sql]
indent_size = 4

# Python files
[*.py]
indent_size = 4

# PowerShell files
[*.ps1]
indent_size = 4

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Batch files
[*.{bat,cmd}]
end_of_line = crlf

# CSV/TSV files
[*.{csv,tsv}]
trim_trailing_whitespace = false
insert_final_newline = false

# Makefiles require tabs
[Makefile]
indent_style = tab
