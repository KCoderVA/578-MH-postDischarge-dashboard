# .gitattributes for MH PostDischarge Dashboard
# Project: 578-MH-postDischarge-dashboard
# Version: v0.1.0
# =============================================================================
# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf
# ----------------------------
# Explicit text file types
# ----------------------------
*.md text eol=lf diff=markdown
*.txt text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.prompt text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
# Windows-specific files that require CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.vbs text eol=crlf
# ----------------------------
# Binary files (never diff/merge)
# ----------------------------
*.pbix binary filter=lfs diff=lfs merge=lfs -text
*.pbit binary
*.xlsx binary
*.xls binary
*.docx binary
*.pptx binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.msapp binary
*.zip binary
*.7z binary
*.tar.gz binary
*.rar binary
*.exe binary
*.dll binary
*.msi binary
# ----------------------------
# Git LFS tracking
# ----------------------------
# PowerBI files tracked with LFS (per Q4 answer)
*.pbix filter=lfs diff=lfs merge=lfs -text
# Large binary assets
# *.pbit filter=lfs diff=lfs merge=lfs -text
# *.xlsx filter=lfs diff=lfs merge=lfs -text
# ----------------------------
# Linguist overrides (GitHub language detection)
# ----------------------------
docs/** linguist-documentation
*.md linguist-documentation
tests/** linguist-detectable=false
