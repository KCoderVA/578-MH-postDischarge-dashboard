  "version": "0.2.0",
  "configurations": [
    {
      "name": "PowerShell: Launch Current Script",
      "type": "PowerShell",
      "request": "launch",
      "script": "${file}",
      "cwd": "${workspaceFolder}",
      "createTemporaryIntegratedConsole": false
    },
    {
      "name": "PowerShell: Validate License Headers",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/scripts/powershell/validateLicenseHeaders.ps1",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "PowerShell: Append Changelog Entry",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/scripts/powershell/appendChangelogEntry.ps1",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Python: Launch Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Launch Script (scripts/python/)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/python/${input:pythonScript}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ],
  "inputs": [
    {
      "id": "pythonScript",
      "type": "promptString",
      "description": "Enter the Python script filename (e.g., myScript.py)",
      "default": ""
    }
  ]
}
